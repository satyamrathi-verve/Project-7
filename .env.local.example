# Your team's Supabase project — these are already filled in for you in .env.local.
# (The anon key is safe to commit; it only allows the access the database policies permit.)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-TEAM-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-TEAM-ANON-KEY

# Resend email service (for real email sending)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# The "from" email address (must be verified in Resend, or use onboarding@resend.dev for testing)
EMAIL_FROM=Verve Advisory <invoices@yourdomain.com>
